# Copy to .env and fill in the blanks. .env is gitignored; never commit real secrets.
# dotenv syntax is KEY=VALUE (no colons, no spaces around =).

# ── Common ──────────────────────────────────────────────────────────────────
TZ=Asia/Ho_Chi_Minh

# ── API ─────────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
# Public web origin the API allows via CORS (App:AllowedOrigins__0).
ASPNETCORE_WEB_URL=https://fairsharemon.minhkakart.com

# ── Web (build-time; Vite inlines VITE_* into the bundle) ────────────────────
# Production API origin the browser calls directly.
VITE_API_BASE_URL=https://fairsharemon-api.minhkakart.com
# Browser MSW mocking. Leave false in production.
VITE_ENABLE_MOCKS=false

# ── MariaDB ─────────────────────────────────────────────────────────────────
MARIADB_ROOT_PASSWORD=

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ── Seeded admin (optional; leave ADMIN_PASSWORD empty to skip seeding) ──────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
