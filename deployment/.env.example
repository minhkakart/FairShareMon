# Copy to .env and fill in the blanks. .env is gitignored; never commit real secrets.
# dotenv syntax is KEY=VALUE (no colons, no spaces around =).
#
# NOTE: the API's own settings (DB connection, Redis, CORS, Admin, migrations) are NOT here —
# they live in the mounted FairShareMonApi/FairShareMonApi/appsettings.Production.local.json.
# Keep that file's DB/Redis passwords in sync with MARIADB_ROOT_PASSWORD / REDIS_PASSWORD below.

# ── Common ──────────────────────────────────────────────────────────────────
TZ=Asia/Ho_Chi_Minh
ASPNETCORE_ENVIRONMENT=Production

# ── Web (build-time; Vite inlines VITE_* into the bundle) ────────────────────
# Production API origin the browser calls directly.
VITE_API_BASE_URL=https://fairsharemon-api.minhkakart.com
# Browser MSW mocking. Leave false in production.
VITE_ENABLE_MOCKS=false

# ── MariaDB (root password for the db container) ────────────────────────────
MARIADB_ROOT_PASSWORD=

# ── Redis (auth password for the redis container) ───────────────────────────
REDIS_PASSWORD=
