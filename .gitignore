# Monorepo root ignore. Subtree-specific ignores live in
# FairShareMonApi/.gitignore (.NET: bin/obj/etc.) and FairShareMonWeb/.gitignore
# (node_modules/dist/etc.); this file is the root-level backstop.

# Claude Code local (per-machine) settings — never version.
.claude/settings.local.json
.claude/settings.json

# Defensive: build/dependency artifacts anywhere in the tree.
**/bin/
**/obj/
**/node_modules/
**/dist/
**/dist-ssr/

# IDE / editor / OS.
.idea/
.vs/
.vscode/
*.user
*.suo
*.DotSettings.user
Thumbs.db
.DS_Store
