# Dev backend origin — consumed by vite.config.ts as the /api proxy TARGET only.
# Client code always calls same-origin /api in dev; Vite proxies it here.
# (Committed http launch profile is :5200; HTTPS is on :7114.)
VITE_API_BASE_URL=http://localhost:5200

# Set to "true" to serve the app against MSW mock handlers in the browser
# instead of the real backend (useful when MariaDB/Redis are unreachable).
VITE_ENABLE_MOCKS=false
