# Production API origin (scheme + host, NO trailing slash), e.g. https://api.fairsharemon.com
# The client appends the versioned /api path itself. Leave empty in dev (the Vite
# proxy serves same-origin /api). Set this at deploy time — there is no production
# deployment yet.
VITE_API_BASE_URL=

# Browser MSW mocking. Leave empty/false outside local mock runs.
VITE_ENABLE_MOCKS=
